function listenOptions(containerId){
  if(!('speechSynthesis' in window))return;
  speechSynthesis.cancel();
  const words=[...document.querySelectorAll('#'+containerId+' button')].map(b=>b.textContent.trim());
  let i=0;
  function next(){
    if(i>=words.length)return;
    const u=speakText(words[i],.8);
    u.onend=()=>{i++;if(i<words.length)setTimeout(next,350)};
    speechSynthesis.speak(u);
  }
  next();
}
